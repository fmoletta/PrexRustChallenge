      "name": "new_client",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code, `Unexpected status ${pm.response.code}. Body: ${pm.response.text()}`).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test(\"Response is JSON when successful\", function () {",
              "    if ([200, 201].includes(pm.response.code)) {",
              "        pm.expect(pm.response.headers.get('Content-Type') || '', 'Missing Content-Type header').to.match(/application\\/json/i);",
              "        pm.response.to.be.json;",
              "    }",
              "});",
              "pm.test(\"Body contains client ID\", function () { var jsonData = pm.response.json(); pm.expect(jsonData).to.equal(0); });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
